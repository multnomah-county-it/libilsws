{
    "name": "multnomah-county-it/libilsws",
    "description": "SirsiDynix ILSWS API Wrapper",
    "type": "library",
    "license": "GPL-3.0-or-later",
    "authors": [
        {
            "name": "John Houser",
            "email": "90853393+john-c-houser@users.noreply.github.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "ext-curl": "*",
        "ext-json": "*",
        "phpmailer/phpmailer": ">=7.0",
        "symfony/yaml": "^6.0|^7.0",
        "twig/twig": ">=3.0"
    },
    "require-dev": {
        "phpunit/phpunit": ">=10.5",
        "symfony/var-dumper": ">=6.0"
    },
    "autoload": {
        "psr-4": {
            "Libilsws\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Libilsws\\Tests\\": "tests/"
        }
    }
